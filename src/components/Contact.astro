---
import FloralAccent from './FloralAccent.astro';
import Sparkle from './Sparkle.astro';
---

<section class="contact section" id="contact">
  <Sparkle count={10} colors={['#d4af37', '#b5667a', '#f0ece2']} class="contact-sparkles" />
  <div class="container">
    <div class="section-title reveal">
      <div class="section-title-floral">
        <FloralAccent variant="sprig" class="sprig-left" />
        <h2>Get in Touch</h2>
        <FloralAccent variant="sprig" class="sprig-right" />
      </div>
      <p class="section-subtitle">For bookings, press, or just to say hello</p>
    </div>

    <div class="contact-grid">
      <form id="contact-form" action="https://api.web3forms.com/submit" method="POST" class="contact-form reveal">
        <input type="hidden" name="access_key" value="79c8cc3b-1931-4842-9e79-098a278230dc">
        <input type="hidden" name="subject" value="New message from slayeratti.band">
        <!-- Honeypot spam protection -->
        <input type="checkbox" name="botcheck" class="visually-hidden" style="display:none" tabindex="-1" autocomplete="off">

        <div class="form-group">
          <label for="contact-name">Name</label>
          <input type="text" id="contact-name" name="fname" placeholder="Your name" required>
        </div>

        <div class="form-group">
          <label for="contact-email">Email</label>
          <input type="email" id="contact-email" name="email" placeholder="your@email.com" pattern="[^@ \t\r\n]+@[^@ \t\r\n]+\.[^@ \t\r\n]+" required>
        </div>

        <div class="form-group">
          <label for="contact-phone">Phone <span class="optional">(optional)</span></label>
          <input type="tel" id="contact-phone" name="phone" placeholder="Your phone number">
        </div>

        <div class="form-group">
          <label for="contact-message">Message</label>
          <textarea id="contact-message" name="message" placeholder="Tell us what's on your mind…" rows="5" required></textarea>
        </div>

        <button type="submit" class="contact-submit" id="submit-btn">
          <span id="submit-btn-text">Send Message</span>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </button>

        <div class="alert-msg" id="alert-msg" aria-live="polite"></div>
      </form>
    </div>
  </div>

  <div class="floral-divider-wrap" aria-hidden="true">
    <FloralAccent variant="divider" class="section-floral-divider" />
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const alertMsg = document.getElementById('alert-msg')!;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const submitBtnText = document.getElementById('submit-btn-text')!;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    submitBtn.disabled = true;
    submitBtnText.textContent = 'Sending…';
    alertMsg.textContent = '';
    alertMsg.className = 'alert-msg';

    try {
      const res = await fetch(form.action, {
        method: 'POST',
        body: new FormData(form),
      });
      const data = await res.json();

      if (data.success) {
        alertMsg.textContent = 'Thank you! Your message has been sent.';
        alertMsg.classList.add('alert-msg--success');
        form.reset();
      } else {
        throw new Error(data.message || 'Something went wrong');
      }
    } catch (err) {
      alertMsg.textContent = 'Oops — something went wrong. Please try again.';
      alertMsg.classList.add('alert-msg--error');
    } finally {
      submitBtn.disabled = false;
      submitBtnText.textContent = 'Send Message';
    }
  });
</script>

<style>
  .contact {
    background: var(--bg-primary);
    position: relative;
    overflow: hidden;
  }

  :global(.contact-sparkles) {
    z-index: 1;
  }

  .section-title-floral {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-sm);
  }

  :global(.sprig-left) {
    width: 100px;
    height: 50px;
    color: var(--accent-green);
    transform: scaleX(-1);
  }

  :global(.sprig-right) {
    width: 100px;
    height: 50px;
    color: var(--accent-green);
  }

  .floral-divider-wrap {
    text-align: center;
    padding: var(--space-md) 0 0;
    color: var(--accent-rose);
  }

  :global(.section-floral-divider) {
    width: min(100%, 400px);
    height: auto;
    margin: 0 auto;
  }

  .contact-grid {
    max-width: 600px;
    margin: 0 auto;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .form-group label {
    font-size: var(--fs-small);
    color: var(--text-secondary);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    font-weight: 500;
  }

  .optional {
    text-transform: none;
    opacity: 0.5;
    font-weight: 400;
  }

  .form-group input,
  .form-group textarea {
    background: var(--bg-card);
    border: 1px solid rgba(240, 236, 226, 0.1);
    border-radius: var(--border-radius);
    padding: 0.85rem 1rem;
    color: var(--text-primary);
    font-family: inherit;
    font-size: var(--fs-body);
    transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
  }

  .form-group input::placeholder,
  .form-group textarea::placeholder {
    color: var(--text-muted);
    opacity: 0.5;
  }

  .form-group input:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--accent-blue);
    box-shadow: 0 0 0 3px rgba(42, 111, 176, 0.15);
  }

  .form-group textarea {
    resize: vertical;
    min-height: 120px;
  }

  .contact-submit {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    align-self: flex-start;
    padding: 0.85rem 2rem;
    background: var(--accent-gold);
    color: var(--bg-primary);
    border: none;
    border-radius: var(--border-radius);
    font-family: inherit;
    font-size: var(--fs-body);
    font-weight: 600;
    letter-spacing: 0.03em;
    cursor: pointer;
    transition: all var(--transition-fast);
  }

  .contact-submit:hover:not(:disabled) {
    background: var(--text-primary);
    transform: translateY(-2px);
    box-shadow: 0 4px 20px rgba(212, 175, 55, 0.3);
  }

  .contact-submit:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .alert-msg {
    font-size: var(--fs-small);
    min-height: 1.4em;
  }

  .alert-msg--success {
    color: var(--accent-green);
  }

  .alert-msg--error {
    color: var(--accent-rose);
  }

  @media (max-width: 480px) {
    .contact-submit {
      width: 100%;
    }
  }
</style>
