---
import FloralAccent from './FloralAccent.astro';
import Sparkle from './Sparkle.astro';
---

<section class="hero" id="hero">
  <div class="hero-bg">
    <canvas id="particle-canvas" aria-hidden="true"></canvas>
    <div class="hero-gradient"></div>
  </div>
  <Sparkle count={30} class="hero-sparkles" />

  <div class="hero-content">
    <div class="hero-botanical hero-botanical--left" aria-hidden="true">
      <FloralAccent variant="vine-left" />
    </div>

    <div class="hero-botanical hero-botanical--right" aria-hidden="true">
      <FloralAccent variant="vine-right" />
    </div>

    <!-- Scattered petals across the hero -->
    <div class="hero-petals" aria-hidden="true">
      <FloralAccent variant="petal-scatter" class="hero-petals-layer hero-petals--1" />
      <FloralAccent variant="petal-scatter" class="hero-petals-layer hero-petals--2" />
    </div>

    <!-- Small rosebuds flanking the content -->
    <div class="hero-rosebud hero-rosebud--left" aria-hidden="true">
      <FloralAccent variant="rosebud" />
    </div>
    <div class="hero-rosebud hero-rosebud--right" aria-hidden="true">
      <FloralAccent variant="rosebud" />
    </div>

    <h1 class="hero-title shimmer-text"><span class="hero-title-slayer">Slayer</span><span class="hero-title-atti">atti</span></h1>
    <p class="hero-tagline">Music, life, & everything in between</p>

    <div class="hero-cta">
      <a href="#music" class="btn btn-primary">Listen Now</a>
      <a href="#shows" class="btn btn-outline">Upcoming Shows</a>
    </div>

    <!-- Trailing vine beneath CTA -->
    <div class="hero-trailing-vine" aria-hidden="true">
      <FloralAccent variant="trailing-vine" class="hero-vine-line" />
    </div>

    <div class="hero-scroll" aria-hidden="true">
      <div class="scroll-line"></div>
    </div>
  </div>
</section>

<script>
  const canvas = document.getElementById('particle-canvas') as HTMLCanvasElement;
  if (canvas) {
    const ctx = canvas.getContext('2d')!;
    let particles: { x: number; y: number; vx: number; vy: number; size: number; opacity: number; color: string }[] = [];
    let animationId: number;

    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    function resize() {
      canvas.width = window.innerWidth;
      canvas.height = window.innerHeight;
    }

    function createParticles() {
      const count = Math.min(60, Math.floor(window.innerWidth / 20));
      const colors = ['rgba(212,175,55,', 'rgba(58,143,212,', 'rgba(181,102,122,'];
      particles = Array.from({ length: count }, () => ({
        x: Math.random() * canvas.width,
        y: Math.random() * canvas.height,
        vx: (Math.random() - 0.5) * 0.3,
        vy: (Math.random() - 0.5) * 0.3,
        size: Math.random() * 2 + 0.5,
        opacity: Math.random() * 0.5 + 0.1,
        color: colors[Math.floor(Math.random() * colors.length)],
      }));
    }

    function animate() {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      particles.forEach((p) => {
        p.x += p.vx;
        p.y += p.vy;
        if (p.x < 0 || p.x > canvas.width) p.vx *= -1;
        if (p.y < 0 || p.y > canvas.height) p.vy *= -1;
        ctx.beginPath();
        ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
        ctx.fillStyle = `${p.color}${p.opacity})`;
        ctx.fill();
      });
      animationId = requestAnimationFrame(animate);
    }

    if (!prefersReducedMotion) {
      resize();
      createParticles();
      animate();
      window.addEventListener('resize', () => { resize(); createParticles(); });
    }
  }
</script>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  #particle-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .hero-gradient {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 20% 50%, var(--accent-blue-glow) 0%, transparent 50%),
      radial-gradient(ellipse at 80% 50%, var(--accent-rose-glow) 0%, transparent 50%),
      radial-gradient(ellipse at 50% 100%, rgba(26, 26, 46, 0.8) 0%, transparent 60%);
  }

  .hero-content {
    position: relative;
    z-index: 1;
    text-align: center;
    padding: var(--space-md);
  }

  .hero-botanical {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    height: 60vh;
    max-height: 500px;
    color: var(--accent-green);
    pointer-events: none;
  }

  .hero-botanical--left {
    left: -2rem;
  }

  .hero-botanical--right {
    right: -2rem;
  }

  .hero-botanical :global(svg) {
    height: 100%;
    width: auto;
  }

  /* Scattered petals */
  .hero-petals {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
  }

  :global(.hero-petals-layer) {
    position: absolute;
    width: 100%;
    height: 100%;
  }

  :global(.hero-petals--1) {
    color: var(--accent-rose);
    opacity: 0.5;
  }

  :global(.hero-petals--2) {
    color: var(--accent-gold);
    opacity: 0.35;
    transform: scaleX(-1) translateY(30px);
  }

  /* Rosebuds beside content */
  .hero-rosebud {
    position: absolute;
    top: 35%;
    pointer-events: none;
  }

  .hero-rosebud :global(svg) {
    width: 40px;
    height: 60px;
  }

  .hero-rosebud--left {
    left: 15%;
    color: var(--accent-rose);
    opacity: 0.7;
    transform: rotate(-15deg);
  }

  .hero-rosebud--right {
    right: 15%;
    color: var(--accent-gold);
    opacity: 0.6;
    transform: rotate(10deg);
  }

  /* Trailing vine under CTA */
  .hero-trailing-vine {
    margin-top: var(--space-md);
    pointer-events: none;
  }

  :global(.hero-vine-line) {
    width: min(100%, 350px);
    height: auto;
    margin: 0 auto;
    color: var(--accent-green);
    opacity: 0.5;
  }

  .hero-overline {
    font-family: var(--font-body);
    font-size: var(--fs-small);
    font-weight: 300;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--text-secondary);
    margin-bottom: var(--space-sm);
  }

  .hero-title {
    font-size: var(--fs-hero);
    font-weight: 400;
    line-height: 1.1;
    padding-bottom: 0.05em;
    margin-bottom: var(--space-sm);
    text-shadow:
      0 0 40px rgba(212, 175, 55, 0.3),
      0 0 80px rgba(212, 175, 55, 0.15);
  }

  .hero-title-slayer {
    font-family: 'Dancing Script', cursive;
    font-weight: 700;
    font-size: 1.15em;
    letter-spacing: 0.01em;
  }

  .hero-title-atti {
    font-family: 'Forum', serif;
    font-weight: 400;
    letter-spacing: 0.08em;
  }

  .hero-tagline {
    font-family: var(--font-heading);
    font-size: var(--fs-h3);
    font-weight: 400;
    font-style: italic;
    color: var(--text-secondary);
    margin-bottom: var(--space-lg);
  }

  .hero-cta {
    display: flex;
    gap: var(--space-sm);
    justify-content: center;
    flex-wrap: wrap;
  }

  .hero-scroll {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
  }

  .scroll-line {
    width: 1px;
    height: 60px;
    background: linear-gradient(to bottom, var(--accent-gold), transparent);
    animation: scrollPulse 2s ease-in-out infinite;
  }

  @keyframes scrollPulse {
    0%, 100% { opacity: 0.3; transform: scaleY(1); }
    50% { opacity: 0.8; transform: scaleY(1.2); }
  }

  @media (max-width: 768px) {
    .hero-botanical { display: none; }

    .hero-cta {
      flex-direction: column;
      align-items: center;
    }
  }
</style>
