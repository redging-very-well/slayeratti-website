---
import FloralAccent from './FloralAccent.astro';
const socialLinks = [
  { name: 'Instagram', icon: '📷', url: '#' },
  { name: 'YouTube', icon: '▶️', url: '#' },
  { name: 'Spotify', icon: '🎵', url: '#' },
  { name: 'Facebook', icon: '👤', url: '#' },
  { name: 'TikTok', icon: '🎬', url: '#' },
];

const currentYear = new Date().getFullYear();
---

<footer class="footer" id="contact">
  <div class="footer-botanical" aria-hidden="true">
    <svg viewBox="0 0 1200 120" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M0 60 C200 20 400 80 600 40 C800 0 1000 60 1200 30 L1200 120 L0 120Z" fill="var(--bg-card)" opacity="0.5"/>
    </svg>
  </div>

  <div class="footer-content section">
    <div class="container">
      <div class="footer-grid">
        <div class="footer-brand reveal">
          <h2 class="footer-logo shimmer-text">Slayeratti</h2>
          <p class="footer-tagline">Celebrating the excellence of life, music, and everything in between.</p>
        </div>

        <div class="footer-contact reveal">
          <h3>Get in Touch</h3>
          <p>For bookings, press, or just to say hello:</p>
          <a href="mailto:hello@slayeratti.com" class="footer-email">hello@slayeratti.com</a>
        </div>

        <div class="footer-social reveal">
          <h3>Follow Us</h3>
          <div class="social-links">
            {socialLinks.map((link) => (
              <a href={link.url} class="social-link" aria-label={`Follow on ${link.name}`} title={link.name}>
                <span class="social-icon">{link.icon}</span>
              </a>
            ))}
          </div>
        </div>
      </div>

      <div class="footer-bottom reveal">
        <div class="footer-ornament" aria-hidden="true">
          <FloralAccent variant="divider" class="footer-floral-divider" />
        </div>
        <p class="footer-copyright">
          &copy; {currentYear} Slayeratti. All rights reserved.
        </p>
        <p class="footer-made-with">
          Made with ♫ and a whole lot of soul
        </p>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    position: relative;
    background: var(--bg-card);
  }

  .footer-botanical {
    position: absolute;
    top: -1px;
    left: 0;
    right: 0;
    height: 80px;
    pointer-events: none;
  }

  .footer-botanical svg {
    width: 100%;
    height: 100%;
  }

  .footer-content {
    padding-top: var(--space-2xl);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: var(--space-lg);
    margin-bottom: var(--space-lg);
  }

  .footer-brand {
    text-align: center;
  }

  .footer-logo {
    font-family: var(--font-heading);
    font-size: var(--fs-h1);
    font-weight: 800;
    letter-spacing: 0.04em;
    margin-bottom: var(--space-xs);
  }

  .footer-tagline {
    color: var(--text-secondary);
    font-style: italic;
    max-width: 300px;
    margin: 0 auto;
  }

  .footer-contact {
    text-align: center;
  }

  .footer-contact h3 {
    margin-bottom: var(--space-xs);
  }

  .footer-contact p {
    color: var(--text-muted);
    font-size: var(--fs-small);
    margin-bottom: var(--space-xs);
  }

  .footer-email {
    font-size: var(--fs-body);
    color: var(--accent-gold);
    font-weight: 500;
    letter-spacing: 0.02em;
    position: relative;
  }

  .footer-email:hover {
    color: var(--text-primary);
  }

  .footer-social {
    text-align: center;
  }

  .footer-social h3 {
    margin-bottom: var(--space-sm);
  }

  .social-links {
    display: flex;
    justify-content: center;
    gap: var(--space-sm);
  }

  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    border: 1px solid rgba(240, 236, 226, 0.1);
    font-size: 1.2rem;
    transition: all var(--transition-fast);
  }

  .social-link:hover {
    border-color: var(--accent-gold);
    background: var(--accent-gold-glow);
    transform: translateY(-3px);
  }

  .footer-bottom {
    text-align: center;
    padding-top: var(--space-md);
  }

  .footer-ornament {
    color: var(--accent-gold);
    margin-bottom: var(--space-sm);
  }

  :global(.footer-floral-divider) {
    width: min(100%, 400px);
    height: auto;
    margin: 0 auto;
  }

  .footer-copyright {
    font-size: var(--fs-small);
    color: var(--text-muted);
    margin-bottom: 0.25rem;
  }

  .footer-made-with {
    font-size: var(--fs-small);
    color: var(--text-muted);
    opacity: 0.6;
  }
</style>
