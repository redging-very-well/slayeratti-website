---
import FloralAccent from './FloralAccent.astro';
import Sparkle from './Sparkle.astro';

import haberdasheryAudio from '../media/audio/Haberdashery (Scott Point 2026).m4a';
import cruisinAudio from '../media/audio/Cruisin (Scott Point 2026).m4a';
import firestarAudio from '../media/audio/Firestar (Scott Point 2026).m4a';

const tracks = [
  { title: 'Haberdashery (Scott Point 2026)', src: haberdasheryAudio },
  { title: "Cruisin' (Scott Point 2026)", src: cruisinAudio },
  { title: 'Firestar (Scott Point 2026)', src: firestarAudio },
];

const platforms = [
  { name: 'Spotify', icon: '♫', url: '#' },
  { name: 'Apple Music', icon: '♪', url: '#' },
  // { name: 'YouTube', icon: '▶', url: '#' },
  { name: 'SoundCloud', icon: '☁', url: '#' },
];
---

<section class="music section" id="music">
  <Sparkle count={22} colors={['#d4af37', '#3a8fd4', '#f0ece2', '#b5667a']} class="music-sparkles" />
  <div class="music-floral-bg" aria-hidden="true">
    <FloralAccent variant="rose" class="music-bg-rose music-bg-rose--1" />
    <FloralAccent variant="wildflower" class="music-bg-rose music-bg-rose--2" />
    <FloralAccent variant="fern" class="music-bg-fern music-bg-fern--1" />
    <FloralAccent variant="lily" class="music-bg-lily" />
    <FloralAccent variant="petal-scatter" class="music-bg-petals" />
    <FloralAccent variant="rosebud" class="music-bg-rosebud music-bg-rosebud--1" />
    <FloralAccent variant="rosebud" class="music-bg-rosebud music-bg-rosebud--2" />
  </div>
  <div class="container">
    <div class="section-title reveal">
      <div class="section-title-floral">
        <FloralAccent variant="sprig" class="sprig-left" />
        <h2>Recent Tracks</h2>
        <FloralAccent variant="sprig" class="sprig-right" />
      </div>
      <p class="section-subtitle">From whispered ballads to electric anthems</p>
    </div>

    <div class="track-list">
      {tracks.map((track, i) => (
        <article class="track-item reveal" style={`--delay: ${i * 0.1}s`}>
          <div class="track-number">{String(i + 1).padStart(2, '0')}</div>
          <div class="track-info">
            <h3 class="track-title">{track.title}</h3>
            <div class="player" data-src={track.src}>
              <button class="player-play" aria-label="Play">
                <svg class="icon-play" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><polygon points="6,3 20,12 6,21"/></svg>
                <svg class="icon-pause" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" style="display:none"><rect x="5" y="3" width="4" height="18"/><rect x="15" y="3" width="4" height="18"/></svg>
              </button>
              <span class="player-time player-current">0:00</span>
              <div class="player-progress" role="slider" aria-label="Seek" aria-valuemin="0" aria-valuemax="100" aria-valuenow="0" tabindex="0">
                <div class="player-progress-fill"></div>
              </div>
              <span class="player-time player-duration">0:00</span>
            </div>
          </div>
        </article>
      ))}
    </div>

    <div class="music-trailing-vine" aria-hidden="true">
      <FloralAccent variant="trailing-vine" class="music-vine-line" />
    </div>

    <div class="platforms reveal">
      <p class="platforms-label">Listen on</p>
      <div class="platform-links">
        {platforms.map((p) => (
          <a href={p.url} class="platform-link" aria-label={`Listen on ${p.name}`}>
            <span class="platform-icon">{p.icon}</span>
            <span class="platform-name">{p.name}</span>
          </a>
        ))}
      </div>
    </div>

    <div class="floral-divider-wrap" aria-hidden="true">
      <FloralAccent variant="divider" class="section-floral-divider" />
    </div>
  </div>
</section>

<script>
  function formatTime(s: number): string {
    if (!isFinite(s)) return '0:00';
    const m = Math.floor(s / 60);
    const sec = Math.floor(s % 60);
    return `${m}:${sec.toString().padStart(2, '0')}`;
  }

  let currentAudio: HTMLAudioElement | null = null;
  let currentPlayer: HTMLElement | null = null;

  document.querySelectorAll<HTMLElement>('.player').forEach((player) => {
    const src = player.dataset.src!;
    const playBtn = player.querySelector<HTMLButtonElement>('.player-play')!;
    const iconPlay = player.querySelector<SVGElement>('.icon-play')!;
    const iconPause = player.querySelector<SVGElement>('.icon-pause')!;
    const progressBar = player.querySelector<HTMLElement>('.player-progress')!;
    const progressFill = player.querySelector<HTMLElement>('.player-progress-fill')!;
    const currentTime = player.querySelector<HTMLElement>('.player-current')!;
    const durationEl = player.querySelector<HTMLElement>('.player-duration')!;

    let audio: HTMLAudioElement | null = null;
    let dragging = false;

    function getAudio(): HTMLAudioElement {
      if (!audio) {
        audio = new Audio(src);
        audio.preload = 'metadata';

        audio.addEventListener('loadedmetadata', () => {
          durationEl.textContent = formatTime(audio!.duration);
        });

        audio.addEventListener('timeupdate', () => {
          if (dragging) return;
          const pct = audio!.duration ? (audio!.currentTime / audio!.duration) * 100 : 0;
          progressFill.style.width = `${pct}%`;
          currentTime.textContent = formatTime(audio!.currentTime);
        });

        audio.addEventListener('ended', () => {
          iconPlay.style.display = '';
          iconPause.style.display = 'none';
          progressFill.style.width = '0%';
          currentTime.textContent = '0:00';
          currentAudio = null;
          currentPlayer = null;
        });
      }
      return audio;
    }

    function showPlaying() {
      iconPlay.style.display = 'none';
      iconPause.style.display = '';
    }

    function showPaused() {
      iconPlay.style.display = '';
      iconPause.style.display = 'none';
    }

    playBtn.addEventListener('click', () => {
      const a = getAudio();
      if (currentAudio && currentAudio !== a) {
        currentAudio.pause();
        if (currentPlayer) {
          currentPlayer.querySelector<SVGElement>('.icon-play')!.style.display = '';
          currentPlayer.querySelector<SVGElement>('.icon-pause')!.style.display = 'none';
        }
      }
      if (a.paused) {
        a.play();
        showPlaying();
        currentAudio = a;
        currentPlayer = player;
      } else {
        a.pause();
        showPaused();
      }
    });

    function seek(e: MouseEvent | Touch) {
      const a = getAudio();
      const rect = progressBar.getBoundingClientRect();
      const pct = Math.max(0, Math.min(1, (e.clientX - rect.left) / rect.width));
      if (a.duration) a.currentTime = pct * a.duration;
      progressFill.style.width = `${pct * 100}%`;
      currentTime.textContent = formatTime(a.currentTime);
    }

    progressBar.addEventListener('mousedown', (e) => {
      dragging = true;
      seek(e);
      const onMove = (ev: MouseEvent) => seek(ev);
      const onUp = () => { dragging = false; window.removeEventListener('mousemove', onMove); window.removeEventListener('mouseup', onUp); };
      window.addEventListener('mousemove', onMove);
      window.addEventListener('mouseup', onUp);
    });

    progressBar.addEventListener('touchstart', (e) => {
      dragging = true;
      seek(e.touches[0]);
    }, { passive: true });

    progressBar.addEventListener('touchmove', (e) => {
      if (dragging) seek(e.touches[0]);
    }, { passive: true });

    progressBar.addEventListener('touchend', () => { dragging = false; });

    // Keyboard support for the slider
    progressBar.addEventListener('keydown', (e) => {
      const a = getAudio();
      if (!a.duration) return;
      if (e.key === 'ArrowRight') { a.currentTime = Math.min(a.duration, a.currentTime + 5); }
      else if (e.key === 'ArrowLeft') { a.currentTime = Math.max(0, a.currentTime - 5); }
    });
  });
</script>

<style>
  .music {
    background: var(--bg-secondary);
    position: relative;
    overflow: hidden;
  }

  :global(.music-sparkles) {
    z-index: 1;
  }

  .music-floral-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }

  :global(.music-bg-rose) {
    position: absolute;
  }

  :global(.music-bg-rose--1) {
    top: 5%;
    right: -15px;
    width: 160px;
    height: 160px;
    color: var(--accent-rose);
  }

  :global(.music-bg-rose--2) {
    bottom: 10%;
    left: -10px;
    width: 130px;
    height: 160px;
    color: var(--accent-gold);
  }

  :global(.music-bg-fern--1) {
    position: absolute;
    top: 15%;
    left: 3%;
    width: 50px;
    height: 140px;
    color: var(--accent-green);
    opacity: 0.5;
    transform: rotate(10deg);
  }

  :global(.music-bg-lily) {
    position: absolute;
    bottom: 20%;
    right: 8%;
    width: 100px;
    height: 120px;
    color: var(--accent-rose);
    opacity: 0.4;
  }

  :global(.music-bg-petals) {
    position: absolute;
    top: 30%;
    left: 10%;
    width: 180px;
    height: 180px;
    color: var(--accent-gold);
    opacity: 0.25;
  }

  :global(.music-bg-rosebud) {
    position: absolute;
  }

  :global(.music-bg-rosebud--1) {
    top: 40%;
    right: 3%;
    width: 35px;
    height: 55px;
    color: var(--accent-rose);
    opacity: 0.6;
    transform: rotate(-20deg);
  }

  :global(.music-bg-rosebud--2) {
    bottom: 35%;
    left: 5%;
    width: 30px;
    height: 48px;
    color: var(--accent-blue);
    opacity: 0.5;
    transform: rotate(15deg);
  }

  .music-trailing-vine {
    text-align: center;
    padding: var(--space-sm) 0;
    pointer-events: none;
  }

  :global(.music-vine-line) {
    width: min(100%, 320px);
    height: auto;
    margin: 0 auto;
    color: var(--accent-green);
    opacity: 0.45;
  }

  .music .container {
    position: relative;
    z-index: 1;
  }

  .section-title-floral {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-sm);
  }

  :global(.sprig-left) {
    width: 100px;
    height: 50px;
    color: var(--accent-green);
    transform: scaleX(-1);
  }

  :global(.sprig-right) {
    width: 100px;
    height: 50px;
    color: var(--accent-green);
  }

  .floral-divider-wrap {
    text-align: center;
    padding: var(--space-md) 0 0;
    color: var(--accent-green);
  }

  :global(.section-floral-divider) {
    width: min(100%, 400px);
    height: auto;
    margin: 0 auto;
  }

  .track-list {
    display: flex;
    flex-direction: column;
    gap: 2px;
    margin-bottom: var(--space-lg);
  }

  .track-item {
    display: grid;
    grid-template-columns: auto 1fr;
    align-items: center;
    gap: var(--space-md);
    padding: var(--space-sm) var(--space-md);
    background: var(--bg-card);
    border-radius: var(--border-radius);
    transition: background var(--transition-fast), transform var(--transition-fast);
    transition-delay: var(--delay);
    cursor: default;
  }

  .track-item:hover {
    background: var(--bg-elevated);
    transform: translateX(4px);
  }

  .track-number {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--text-muted);
    min-width: 2.5rem;
  }

  .track-info {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    min-width: 0;
  }

  .track-title {
    font-size: var(--fs-body);
    font-weight: 600;
  }

  .track-audio {
    width: 100%;
    max-width: 500px;
    height: 36px;
    border-radius: 18px;
    filter: invert(1) hue-rotate(180deg) brightness(0.85) contrast(0.9);
  }

  .player {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    width: 100%;
    max-width: 500px;
  }

  .player-play {
    flex-shrink: 0;
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(240, 236, 226, 0.08);
    border: 1px solid rgba(240, 236, 226, 0.12);
    border-radius: 50%;
    color: var(--accent-gold);
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .player-play:hover {
    background: var(--accent-gold-glow);
    border-color: var(--accent-gold);
  }

  .player-play svg {
    width: 18px;
    height: 18px;
  }

  .player-time {
    font-size: 0.75rem;
    color: var(--text-muted);
    font-variant-numeric: tabular-nums;
    min-width: 2.5rem;
    text-align: center;
    flex-shrink: 0;
    user-select: none;
  }

  .player-progress {
    flex: 1;
    height: 44px;
    display: flex;
    align-items: center;
    cursor: pointer;
    position: relative;
    touch-action: none;
  }

  .player-progress::before {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    height: 6px;
    background: rgba(240, 236, 226, 0.1);
    border-radius: 3px;
  }

  .player-progress-fill {
    position: absolute;
    left: 0;
    height: 6px;
    width: 0%;
    background: var(--accent-gold);
    border-radius: 3px;
    pointer-events: none;
    transition: width 0.1s linear;
  }

  .player-progress-fill::after {
    content: '';
    position: absolute;
    right: -8px;
    top: 50%;
    transform: translateY(-50%);
    width: 16px;
    height: 16px;
    background: var(--accent-gold);
    border-radius: 50%;
    box-shadow: 0 0 6px rgba(212, 175, 55, 0.4);
  }

  .platforms {
    text-align: center;
  }

  .platforms-label {
    font-size: var(--fs-small);
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    margin-bottom: var(--space-sm);
  }

  .platform-links {
    display: flex;
    justify-content: center;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  .platform-link {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    padding: 0.5rem 1rem;
    border: 1px solid rgba(240, 236, 226, 0.1);
    border-radius: var(--border-radius);
    color: var(--text-secondary);
    font-size: var(--fs-small);
    transition: all var(--transition-fast);
  }

  .platform-link:hover {
    border-color: var(--accent-gold);
    color: var(--accent-gold);
    background: var(--accent-gold-glow);
  }

  .platform-icon {
    font-size: 1.2rem;
  }

  @media (max-width: 768px) {
    .track-item {
      grid-template-columns: auto 1fr;
      gap: var(--space-sm);
    }
  }
</style>
