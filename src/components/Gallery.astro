---
import { Image } from 'astro:assets';
import FloralAccent from './FloralAccent.astro';
import Sparkle from './Sparkle.astro';

import dsc0099 from '../media/images/DSC_0099.JPG';
import dsc0384 from '../media/images/DSC_0384.JPG';
import img0410 from '../media/images/IMG_0410.JPG';
import img1476 from '../media/images/IMG_1476.JPG';
import img2489 from '../media/images/IMG_2489.JPG';
import img2490 from '../media/images/IMG_2490.JPG';
import img2491 from '../media/images/IMG_2491.JPG';
import img2985 from '../media/images/IMG_2985.jpeg';

const galleryItems = [
  { src: dsc0099, alt: 'Slayeratti performing live on stage', aspect: 'landscape' },
  { src: img2985, alt: 'Portrait shot from a Slayeratti performance', aspect: 'portrait' },
  { src: dsc0384, alt: 'Slayeratti duo in the spotlight', aspect: 'square' },
  { src: img1476, alt: 'Intimate acoustic set under warm lights', aspect: 'square' },
  { src: img0410, alt: 'Electric energy — Slayeratti on stage', aspect: 'landscape' },
  { src: img2489, alt: 'Cinematic wide shot of a live performance', aspect: 'landscape' },
  { src: img2490, alt: 'Slayeratti in full flight on stage', aspect: 'square' },
  { src: img2491, alt: 'Slayeratti — music, life, and everything in between', aspect: 'square' },
];
---

<section class="gallery section" id="gallery">
  <Sparkle count={15} colors={['#d4af37', '#b5667a', '#f0ece2']} class="gallery-sparkles" />
  <div class="gallery-bg-florals" aria-hidden="true">
    <FloralAccent variant="peony" class="gallery-bg-peony" />
    <FloralAccent variant="lily" class="gallery-bg-lily" />
    <FloralAccent variant="rosebud" class="gallery-bg-rosebud gallery-bg-rosebud--1" />
    <FloralAccent variant="rosebud" class="gallery-bg-rosebud gallery-bg-rosebud--2" />
  </div>
  <div class="container">
    <div class="section-title reveal">
      <div class="section-title-floral">
        <FloralAccent variant="sprig" class="sprig-left" />
        <h2>Gallery</h2>
        <FloralAccent variant="sprig" class="sprig-right" />
      </div>
      <p class="section-subtitle">Moments from the stage and beyond</p>
    </div>

    <div class="gallery-grid">
      {galleryItems.map((item, i) => (
        <div class={`gallery-item gallery-item--${item.aspect} reveal`} style={`--delay: ${i * 0.08}s`}>
          <Image
            src={item.src}
            alt={item.alt}
            widths={[400, 800, 1200]}
            sizes="(max-width: 480px) 100vw, (max-width: 768px) 50vw, 33vw"
            format="webp"
            quality={80}
            loading={i < 2 ? 'eager' : 'lazy'}
            class="gallery-image"
          />
        </div>
      ))}
    </div>
  </div>

  <div class="floral-divider-wrap" aria-hidden="true">
    <FloralAccent variant="divider" class="section-floral-divider" />
  </div>
</section>

<style>
  .gallery {
    background: var(--bg-secondary);
    position: relative;
    overflow: hidden;
  }

  :global(.gallery-sparkles) {
    z-index: 1;
  }

  .gallery-bg-florals {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  :global(.gallery-bg-peony) {
    position: absolute;
    top: 5%;
    right: -15px;
    width: 140px;
    height: 140px;
    color: var(--accent-rose);
    opacity: 0.35;
  }

  :global(.gallery-bg-lily) {
    position: absolute;
    bottom: 10%;
    left: -10px;
    width: 100px;
    height: 130px;
    color: var(--accent-gold);
    opacity: 0.3;
  }

  :global(.gallery-bg-rosebud) {
    position: absolute;
  }

  :global(.gallery-bg-rosebud--1) {
    top: 35%;
    left: 5%;
    width: 30px;
    height: 50px;
    color: var(--accent-rose);
    opacity: 0.5;
    transform: rotate(-15deg);
  }

  :global(.gallery-bg-rosebud--2) {
    bottom: 25%;
    right: 6%;
    width: 28px;
    height: 45px;
    color: var(--accent-blue);
    opacity: 0.4;
    transform: rotate(20deg);
  }

  .section-title-floral {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-sm);
  }

  :global(.sprig-left) {
    width: 100px;
    height: 50px;
    color: var(--accent-green);
    transform: scaleX(-1);
  }

  :global(.sprig-right) {
    width: 100px;
    height: 50px;
    color: var(--accent-green);
  }

  .floral-divider-wrap {
    text-align: center;
    padding: var(--space-md) 0 0;
    color: var(--accent-rose);
  }

  :global(.section-floral-divider) {
    width: min(100%, 400px);
    height: auto;
    margin: 0 auto;
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-auto-rows: 280px;
    grid-auto-flow: dense;
    gap: var(--space-sm);
  }

  .gallery-item {
    border-radius: var(--border-radius);
    overflow: hidden;
    transition: transform var(--transition-fast);
    transition-delay: var(--delay);
  }

  .gallery-item:hover {
    transform: scale(1.02);
  }

  .gallery-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    border-radius: var(--border-radius);
    transition: transform 0.4s ease;
  }

  .gallery-item:hover .gallery-image {
    transform: scale(1.05);
  }

  .gallery-item--landscape {
    grid-column: span 2;
  }

  .gallery-item--portrait {
    grid-row: span 2;
  }

  @media (max-width: 768px) {
    .gallery-grid {
      grid-template-columns: repeat(2, 1fr);
      grid-auto-rows: 240px;
    }

    .gallery-item--landscape {
      grid-column: span 2;
    }
  }

  @media (max-width: 480px) {
    .gallery-grid {
      grid-template-columns: 1fr;
      grid-auto-rows: 250px;
    }

    .gallery-item--landscape,
    .gallery-item--portrait {
      grid-column: span 1;
      grid-row: span 1;
    }
  }
</style>
